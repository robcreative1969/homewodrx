{
  "routes": [
    { "src": "/generator",     "headers": { "Location": "/wodbuilder"     }, "status": 301 },
    { "src": "/generator.html","headers": { "Location": "/wodbuilder"     }, "status": 301 },
    { "src": "/stretch$",      "headers": { "Location": "/stretchbuilder" }, "status": 301 },
    { "src": "/stretch.html",  "headers": { "Location": "/stretchbuilder" }, "status": 301 },
    { "src": "/workouts/$",    "headers": { "Location": "/workouts"    }, "status": 301 },
    { "src": "/movements/$",   "headers": { "Location": "/movements"   }, "status": 301 },
    { "src": "/daily-wod/$",   "headers": { "Location": "/daily-wod"   }, "status": 301 },
    { "src": "/stretches/$",   "headers": { "Location": "/stretches"   }, "status": 301 },
    { "src": "/movements/deadlift$",       "headers": { "Location": "/movements/deadlifts"       }, "status": 301 },
    { "src": "/movements/power-clean$",    "headers": { "Location": "/movements/power-cleans"    }, "status": 301 },
    { "src": "/movements/thruster$",       "headers": { "Location": "/movements/thrusters"       }, "status": 301 },
    { "src": "/movements/db-lateral-raise$", "headers": { "Location": "/movements/db-lateral-raises" }, "status": 301 },
    { "src": "/movements/([^/]+)", "dest": "/movement.html" },
    { "src": "/workouts/([^/]+)",  "dest": "/workout.html"  },
    { "src": "/stretches/([^/]+)", "dest": "/stretch-movement.html" },
    { "src": "/stretch-routines/([^/]+)", "dest": "/stretch-routine.html" },
    { "src": "/u/([^/]+)",         "dest": "/profile.html"  },
    { "src": "^/(.*)\\.html$", "headers": { "Location": "/$1" }, "status": 308 },
    { "handle": "filesystem" },
    { "src": "/(.*[^/])$", "dest": "/$1.html", "check": true }
  ]
}
