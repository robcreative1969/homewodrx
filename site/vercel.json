{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/u/:username",       "destination": "/profile?user=:username"   },
    { "source": "/movements/:slug",   "destination": "/movement?slug=:slug"      },
    { "source": "/workouts/:slug",    "destination": "/workout?slug=:slug"       }
  ]
}
